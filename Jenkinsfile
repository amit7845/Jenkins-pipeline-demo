pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                echo "Cloning repository from GitHub"
            }
        }

        stage('Build') {
            steps {
                echo "Building the application"
            }
        }

        stage('Test') {
            steps {
                echo "Running tests"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying application"
            }
        }
    }
}
